VITE_REALTIME_URL=ws://localhost:8787
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8787
REALTIME_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REALTIME_MAX_ROOM_SIZE=8
REALTIME_MAX_CHAT_LENGTH=280
REALTIME_CHAT_WINDOW_MS=10000
REALTIME_CHAT_MAX_MESSAGES=5
REALTIME_MAX_DISPLAY_NAME_LENGTH=32

# On Render, keep VITE_REALTIME_URL unset and let the client use the same origin.
# REALTIME_ALLOWED_ORIGINS can also be left unset there because the server will
# fall back to RENDER_EXTERNAL_URL automatically.
