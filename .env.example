VITE_REALTIME_URL=ws://localhost:8787
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8787
REALTIME_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REALTIME_MAX_ROOM_SIZE=8
REALTIME_MAX_CHAT_LENGTH=280
REALTIME_CHAT_WINDOW_MS=10000
REALTIME_CHAT_MAX_MESSAGES=5
REALTIME_MAX_DISPLAY_NAME_LENGTH=32
REALTIME_LOG_LEVEL=info
REALTIME_COGNITO_USER_POOL_ID=
REALTIME_COGNITO_CLIENT_ID=
REALTIME_COGNITO_ISSUER=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# On Render, keep VITE_REALTIME_URL unset and let the client use the same origin.
# REALTIME_ALLOWED_ORIGINS can also be left unset there because the server will
# fall back to RENDER_EXTERNAL_URL automatically.
# Set REALTIME_COGNITO_USER_POOL_ID and REALTIME_COGNITO_CLIENT_ID so the
# realtime server can verify Amplify/Cognito tokens for room ownership/admin.
# REALTIME_LOG_LEVEL controls structured server log verbosity: debug, info, warn, error.
# REALTIME_COGNITO_ISSUER is optional if the user pool id is provided.
# To persist room owner/admin state in the Amplify backend instead of the local
# fallback JSON file, the realtime server also needs AWS IAM credentials with
# access to the AppSync API generated by Amplify.
